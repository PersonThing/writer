# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. Higher environments use platform-managed secrets
# (Railway env vars for prod, GitHub Actions secrets for CI).

# ── Database ────────────────────────────────────────────────────────────────
# Default points at the dockerized Postgres that `npm run dev` brings up.
DATABASE_URL=postgres://writer:writer@localhost:5434/writer_dev

# ── Session ─────────────────────────────────────────────────────────────────
# Any long random string. Regenerate with:  openssl rand -hex 32
SESSION_SECRET=

# ── Google OAuth ────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client, Web application type.
# Authorized redirect URI must be:  ${APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App URL ─────────────────────────────────────────────────────────────────
# The public URL the browser will use. For local dev this is the Express port
# (the Vite dev server on :5173 proxies /api and /auth through to :3456).
APP_URL=http://localhost:3456

# ── Access control ──────────────────────────────────────────────────────────
# Comma-separated list of Google emails allowed to sign in.
# Playwright's test-login bypass also respects this list.
ALLOWED_EMAILS=
