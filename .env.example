DATABASE_URL=postgres://writer:writer@localhost:5434/writer_dev
SESSION_SECRET=change-me-for-prod

# Required for Google OAuth login (create credentials at
# https://console.cloud.google.com/apis/credentials, OAuth 2.0 Client, Web app type).
# Authorized redirect URI must be ${APP_URL}/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=http://localhost:3456

# Comma-separated allowlist of email addresses that may sign in.
ALLOWED_EMAILS=you@example.com
