{
  "name": "writer",
  "version": "2.0.0",
  "description": "Writing projects manager — web edition",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "npm run db:up && npm run db:migrate && concurrently \"node --watch --env-file=.env.local server/index.js\" \"vite\"",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "build": "vite build",
    "start": "node scripts/migrate.js && node server/index.js",
    "server": "node --env-file=.env.local server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env.local scripts/migrate.js",
    "db:studio": "drizzle-kit studio",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "format": "prettier --write \"src/**/*.{js,svelte,css,html}\" \"server/**/*.js\""
  },
  "dependencies": {
    "@milkdown/crepe": "^7.20.0",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-history": "^7.20.0",
    "@milkdown/plugin-listener": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "connect-pg-simple": "^10.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "node-html-parser": "^7.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}
