{
  "name": "writer",
  "version": "2.0.0",
  "description": "Writing projects manager — web edition",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "npm run db:up && npm run db:migrate && concurrently \"node --watch --env-file=.env server/index.js\" \"vite\"",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "build": "vite build",
    "start": "node scripts/migrate.js && node server/index.js",
    "server": "node --env-file=.env server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env scripts/migrate.js",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write \"src/**/*.{js,svelte,css,html}\" \"server/**/*.js\""
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}
